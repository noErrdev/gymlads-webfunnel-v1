PORT=3001

# Frontend URL (used for Stripe redirect URLs)
CLIENT_URL=http://127.0.0.1:5173

# Optional: base URL encoded in the Redeem Now QR code (defaults to CLIENT_URL/redeem)
# REDEEM_URL=https://gymlads.nl/app

# Stripe (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PRICE_ID=price_your_price_id_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Your n8n Webhook trigger URL (POST)
# Example: https://your-n8n-instance.com/webhook/onboarding
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id
